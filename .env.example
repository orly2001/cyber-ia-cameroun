# Copier en `.env` et adapter. Ne JAMAIS committer le .env réel.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Base de données (PostgreSQL en prod)
DATABASE_URL=postgresql+psycopg2://soc:soc@localhost:5432/soc_cm
USE_SQLITE_FALLBACK=true

# Sources externes
NVD_API_KEY=
ZAP_API_URL=http://localhost:8080
ZAP_API_KEY=

# Moteur IA
PHISHING_THRESHOLD=0.5
BERT_MODEL_NAME=bert-base-multilingual-cased

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Clé d'API protégeant les endpoints sensibles (PATCH /api/alerts/{id},
# POST /api/run-demo). Laisser VIDE => authentification désactivée (dev).
# Définir une valeur forte en production pour exiger l'en-tête X-API-Key.
API_KEY=
