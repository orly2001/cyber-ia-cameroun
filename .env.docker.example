# Configuration de la stack Docker (copier en .env pour personnaliser).
# Toutes ces variables ont des valeurs par defaut : `docker compose up` marche sans .env.

# development => auth desactivee (demo immediate). production => API_KEY EXIGEE.
ENVIRONMENT=development

# Mot de passe PostgreSQL (CHANGER en production).
POSTGRES_PASSWORD=soc

# Cle d'API protegeant les endpoints sensibles (upload, run-demo, patch).
# Obligatoire si ENVIRONMENT=production. La saisir dans la console (champ "Cle API").
API_KEY=

# Seuil de decision du modele (0.23 = calibre pour un meilleur rappel).
PHISHING_THRESHOLD=0.5

# Ports publies sur l'hote.
API_PORT=8000
WEB_PORT=5173

# Origines autorisees par le CORS (doit inclure http://localhost:WEB_PORT).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Assistant IA (Gemini) — definir votre propre cle.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
NMAP_ALLOWED_TARGETS=127.0.0.1,localhost,scanme.nmap.org
